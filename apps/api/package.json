{
  "name": "@brewspace/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/app.ts",
    "start": "bun run src/app.ts",
    "build": "bun build src/app.ts --outdir dist --target bun",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/database/migrate.ts",
    "db:seed": "bun run src/database/seed.ts"
  },
  "dependencies": {
    "@brewspace/contracts": "workspace:*",
    "elysia": "^1.2.10",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/swagger": "^1.2.0",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "ioredis": "^5.4.2",
    "zod": "^3.24.1",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@brewspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.30.2",
    "vitest": "^2.1.8",
    "typescript": "^5.7.3",
    "@types/bun": "latest"
  }
}
